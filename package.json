{
  "name": "augmenta-sec",
  "version": "0.1.0",
  "description": "AI-powered security engineer that onboards to any codebase",
  "type": "module",
  "bin": {
    "augmenta-sec": "./dist/index.js",
    "asec": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "@vitest/coverage-v8": "^3.1.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/augmenta-sec/augmenta-sec"
  },
  "keywords": [
    "security",
    "sast",
    "devsecops",
    "code-analysis",
    "ai-security"
  ]
}
