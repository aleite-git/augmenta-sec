{
  "name": "augmenta-sec",
  "version": "0.1.0",
  "description": "AI-powered security engineer that onboards to any codebase",
  "type": "module",
  "bin": {
    "augmenta-sec": "./dist/index.js",
    "asec": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.0",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "openai": "^6.32.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.15.0",
    "@vitest/coverage-v8": "^3.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.0",
    "prettier": "^3.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/augmenta-sec/augmenta-sec"
  },
  "keywords": [
    "security",
    "sast",
    "devsecops",
    "code-analysis",
    "ai-security"
  ]
}
