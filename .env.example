# AugmentaSec — API Keys
# Copy to .env and fill in the keys for the providers you use.
# You only need keys for providers referenced in your config.yaml.

# ── Google Gemini ──
# Get your key: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ── Mistral AI ──
# Get your key: https://console.mistral.ai/
MISTRAL_API_KEY=

# ── OpenAI ──
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ── Anthropic (Claude) ──
# Get your key: https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# ── Ollama (local) ──
# No key needed. Just install Ollama and pull models.
# Default endpoint: http://localhost:11434
# OLLAMA_HOST=http://localhost:11434
